{
  "command_timeout": 5,
  "templates_folder": "Templates",
  "templates_pairs": [
    [
      "",
      ""
    ]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": true,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "",
  "enable_folder_templates": true,
  "folder_templates": [
    {
      "folder": "Theses",
      "template": "Templates/Thesis Template.MD"
    },
    {
      "folder": "Research",
      "template": "Templates/Research Template.md"
    },
    {
      "folder": "Macro",
      "template": "Templates/Macro Template.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [
    "Templates/_callouts/user-question.md",
    "Templates/_callouts/user-tip.md",
    "Templates/_callouts/user-todo.md",
    "Templates/_callouts/user-warning.md"
  ],
  "startup_templates": [
    ""
  ],
  "intellisense_render": 1
}