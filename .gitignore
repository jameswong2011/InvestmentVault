# ============================================
# Obsidian — personal UI state
# ============================================
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/workspace.json.bak
.obsidian/cache
.obsidian/app.json.bak
.trash/

# ============================================
# Claudian plugin — ignore entire plugin state folder
# ============================================
.claudian/

# ============================================
# Claude Code — keep skills/commands/CLAUDE.md tracked, ignore local settings
# ============================================
.claude/settings.local.json
.claude.json.backup

# ============================================
# Vault runtime state markers (ephemeral, machine-local, never content)
# ============================================
# Written by /sync (watermark); read by subsequent /sync runs to find changed files.
.last_sync
# Written by /sync all; read and deleted by /graph to force a full rebuild after brute-force sync.
.sync_all_fresh
# Written by /status Step 7.6 and /prune Stage 4.5 on closure; read and cleared by /graph last
# to re-extract adjacency for neighbor theses that cross-referenced the now-archived thesis.
.graph_invalidations

# ============================================
# Secrets — NEVER commit these
# ============================================
.env
.env.local
.env.*.local
*.key
*.pem
credentials.json
secrets.json

# ============================================
# macOS system files
# ============================================
.DS_Store
._*
.Spotlight-V100
.Trashes

# ============================================
# Windows system files
# ============================================
Thumbs.db
desktop.ini

# ============================================
# Temp and backup files
# ============================================
*.tmp
*.swp
*.swo
*~
~$*
.obsidian/plugins/claudian/data.json
.obsidian/plugins/claudian/data.json
.claude/settings.json
